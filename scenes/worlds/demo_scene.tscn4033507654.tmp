[sub_resource type="GDScript" id="GDScript_p5q2i"]
script/source = "extends EventHandler

@export var anim_player: AnimationPlayer

func _ready() -> void:
	StateGlobal.stateAdded.connect(func (_stateName: Array[StringName]): eventTriggered.emit())


func _on_event_triggered() -> void:
	anim_player.play(\"falling platforms\")
	
	Input.start_joy_vibration(0, 1.0, 1.0, 1)
	
	for child in get_children():
		var sprite = child as Sprite3D
		if sprite:
			sprite.show()
"

